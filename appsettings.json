{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MassTransit": "Warning",
      "PullRequestAnalyzer.Services": "Debug",
      "PullRequestAnalyzer.Middleware": "Information"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": false,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff",
        "UseUtcTimestamp": true,
        "JsonWriterOptions": {
          "Indented": false
        }
      }
    }
  },
  "AllowedHosts": "*",
  "GitHub": {
    "Token": "",
    "RateLimitBuffer": 100,
    "MaxRetries": 3
  },
  "OpenRouter": {
    "ApiKey": "",
    "Model": "anthropic/claude-3.5-sonnet",
    "MaxTokens": 4096,
    "Temperature": 0.2,
    "TimeoutSeconds": 120
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "CacheTTLHours": 24,
    "GitHubCacheTTLHours": 1,
    "PromptTemplateTTLDays": 90
  },
  "Langfuse": {
    "PublicKey": "",
    "SecretKey": "",
    "OtelEndpoint": "https://us.cloud.langfuse.com/api/public/otel",
    "Enabled": true
  },
  "RateLimiting": {
    "Enabled": true,
    "WindowSizeSeconds": 60,
    "MaxRequestsPerWindow": 60,
    "EndpointLimits": {
      "/api/analyze": {
        "MaxRequests": 10,
        "WindowSizeSeconds": 60
      },
      "/api/pull-requests": {
        "MaxRequests": 100,
        "WindowSizeSeconds": 60
      }
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "",
    "EnableAdaptiveSampling": true,
    "EnableDependencyTracking": true
  }
}
