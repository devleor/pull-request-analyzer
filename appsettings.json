{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MassTransit": "Warning",
      "PullRequestAnalyzer.Services": "Debug",
      "PullRequestAnalyzer.Middleware": "Information"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": false,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss.fff",
        "UseUtcTimestamp": true,
        "JsonWriterOptions": {
          "Indented": false
        }
      }
    }
  },
  "AllowedHosts": "*",
  "Analysis": {
    "Llm": {
      "MaxTokens": 4096,
      "PromptTokensEstimate": 4,
      "Timeout": "00:02:00",
      "Temperature": 0.2,
      "ModelCosts": {
        "claude-3.5-sonnet": 3.00,
        "gpt-4o": 5.00,
        "gemini": 0.15,
        "llama": 0.18,
        "default": 1.00
      }
    },
    "Cache": {
      "PullRequestTtl": "00:10:00",
      "AnalysisTtl": "01:00:00",
      "JobTtl": "24:00:00"
    },
    "Processing": {
      "MaxPatchLength": 2000,
      "MaxLogLength": 500,
      "MaxCommitsToShow": 20,
      "MaxFilesToShow": 5
    },
    "Validation": {
      "MinConfidenceScore": 0.5,
      "MaxMissingFilesRatio": 0.3,
      "ConfidenceLevels": {
        "high": 0.95,
        "medium": 0.75,
        "low": 0.50
      }
    }
  },
  "GitHub": {
    "Token": "",
    "RateLimitBuffer": 100,
    "MaxRetries": 3
  },
  "OpenRouter": {
    "ApiKey": "",
    "Model": "anthropic/claude-3.5-sonnet",
    "MaxTokens": 4096,
    "Temperature": 0.2,
    "TimeoutSeconds": 120
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "CacheTTLHours": 24,
    "GitHubCacheTTLHours": 1,
    "PromptTemplateTTLDays": 90
  },
  "Langfuse": {
    "PublicKey": "",
    "SecretKey": "",
    "OtelEndpoint": "https://us.cloud.langfuse.com/api/public/otel",
    "Enabled": true
  },
  "RateLimiting": {
    "Enabled": true,
    "WindowSizeSeconds": 60,
    "MaxRequestsPerWindow": 60,
    "EndpointLimits": {
      "/api/analyze": {
        "MaxRequests": 10,
        "WindowSizeSeconds": 60
      },
      "/api/pull-requests": {
        "MaxRequests": 100,
        "WindowSizeSeconds": 60
      }
    }
  },
  "ApplicationInsights": {
    "ConnectionString": "",
    "EnableAdaptiveSampling": true,
    "EnableDependencyTracking": true
  }
}
