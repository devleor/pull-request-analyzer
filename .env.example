# Pull Request Analyzer — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Personal Access Token with `repo` and `read:user` scopes.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# ── OpenRouter (LLM — BYOK) ────────────────────────────────────────────────────
# API key for OpenRouter.ai to access LLM models.
# Generate at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Model to use via OpenRouter. Recommended options:
#   anthropic/claude-3.5-sonnet   (best quality)
#   openai/gpt-4o                 (great quality)
#   meta-llama/llama-3.1-70b-instruct (open source, low cost)
#   google/gemini-flash-1.5       (fast, low cost)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── Redis ──────────────────────────────────────────────────────────────────────
# Used for: cache, Redis Streams queue, RedLock distributed locking, prompt templates.
# Default works with the included docker-compose.yml.
REDIS_URL=localhost:6379

# ── Langfuse (LLM Observability via OpenTelemetry) ───────────────────────────
# Track token usage, latency, and costs for LLM calls
# Get your keys at: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
# Optional: Custom OTEL endpoint (defaults to https://cloud.langfuse.com/api/public/otel)
# LANGFUSE_OTEL_ENDPOINT=https://cloud.langfuse.com/api/public/otel

# ── API Server ─────────────────────────────────────────────────────────────────
ASPNETCORE_URLS=http://localhost:5000
ASPNETCORE_ENVIRONMENT=Development

# ── Webhook (Optional) ─────────────────────────────────────────────────────────
# Default webhook URL notified when analysis completes.
# Can also be provided per-request in POST /api/v2/analyze-async.
DEFAULT_WEBHOOK_URL=
