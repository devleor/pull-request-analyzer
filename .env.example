# =============================================================================
# Pull Request Analyzer - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# GITHUB API
# -----------------------------------------------------------------------------
# Personal Access Token with `repo` and `read:user` scopes.
# Generate at: https://github.com/settings/tokens
# Required for fetching PR data, commits, and diffs from GitHub.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your_github_token_here


# -----------------------------------------------------------------------------
# OPENROUTER (LLM - BYOK)
# -----------------------------------------------------------------------------
# API key for OpenRouter.ai to access LLM models.
# Generate at: https://openrouter.ai/keys
# Required for running the LLM analysis workflow.
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# LLM model to use via OpenRouter.
# Recommended models:
#   - anthropic/claude-3.5-sonnet    (best quality, higher cost)
#   - openai/gpt-4o                  (great quality, moderate cost)
#   - meta-llama/llama-3.1-70b-instruct (open source, low cost)
#   - google/gemini-flash-1.5        (fast, low cost)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet


# -----------------------------------------------------------------------------
# RABBITMQ
# -----------------------------------------------------------------------------
# Message broker for async processing.
# Default values work with the included docker-compose.yml.
# Change these if connecting to an external RabbitMQ instance.
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# RabbitMQ Management UI (optional, only needed for monitoring)
RABBITMQ_MANAGEMENT_PORT=15672


# -----------------------------------------------------------------------------
# API SERVER
# -----------------------------------------------------------------------------
# Port the ASP.NET Core API listens on.
ASPNETCORE_URLS=http://localhost:5000
ASPNETCORE_ENVIRONMENT=Development


# -----------------------------------------------------------------------------
# STORAGE (File-based, for local prototype)
# -----------------------------------------------------------------------------
# Directories for persisting data locally.
# These are created automatically if they don't exist.
PR_DATA_DIRECTORY=./pr_data
ANALYSIS_RESULTS_DIRECTORY=./analysis_results
JOB_STATUS_DIRECTORY=./job_status


# -----------------------------------------------------------------------------
# WEBHOOK (Optional)
# -----------------------------------------------------------------------------
# Default webhook URL to notify when analysis completes.
# Can also be provided per-request in the POST /api/v2/analyze-async body.
# Leave empty to disable default webhook notifications.
DEFAULT_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# OPTIONAL: OPENAI (Alternative to OpenRouter)
# -----------------------------------------------------------------------------
# If you prefer to use OpenAI directly instead of OpenRouter.
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_MODEL=gpt-4o
