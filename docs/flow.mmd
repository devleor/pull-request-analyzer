flowchart TD
    subgraph CLIENT["👤 Client"]
        C1([HTTP Request])
        C2([Poll Status])
        C3([Webhook Receiver])
    end

    subgraph API["🌐 ASP.NET Core API"]
        A1[POST /api/v2/analyze-async]
        A2[GET /api/v2/jobs/:jobId]
    end

    subgraph WORKER["⚙️ RedisBackgroundWorker\n(IHostedService)"]
        W1[ProcessAsync]
        W2[LLMAnalysisService]
        W3[WebhookService]
    end

    subgraph REDIS["💾 Redis"]
        R1["queue:analyze (Stream)"]
        R2["cache:pr:* (String)"]
        R3["cache:analysis:* (String)"]
        R4["job:* (String)"]
        R5["lock:analyze:* (String)"]
    end

    subgraph EXTERNAL["🔌 External Services"]
        E1[(GitHub API)]
        E2[(OpenRouter LLM)]
    end

    %% Client → API
    C1 -->|"POST /analyze-async\n{pr_data, webhook_url}"| A1
    C2 -->|"GET /jobs/:jobId"| A2

    %% API → Redis
    A1 -->|"1. Create job (queued)"| R4
    A1 -->|"2. LPUSH to queue:analyze"| R1
    A1 -->|"3. Return 202 + job_id"| C1

    %% Worker → Redis (Queue)
    W1 -->|"XREADGROUP from queue:analyze"| R1

    %% Worker flow
    W1 -->|"Acquire lock"| R5
    W1 -->|"Check cache"| R3
    W1 -->|"Analyze PR"| W2
    W2 -->|"Fetch from GitHub"| E1
    E1 -->|"Cache PR data"| R2
    W2 -->|"Prompt + diffs"| E2
    E2 -->|"Structured analysis"| W2
    W2 -->|"Cache analysis"| R3
    W1 -->|"Update job status"| R4
    W1 -->|"Notify client"| W3
    W3 -->|"POST webhook"| C3

    %% Status polling
    A2 -->|"Read job"| R4

    %% Styles
    classDef apiStyle fill:#4A90D9,stroke:#2C5F8A,color:#fff
    classDef workerStyle fill:#7B68EE,stroke:#4B3DB5,color:#fff
    classDef redisStyle fill:#D82C20,stroke:#A31F17,color:#fff
    classDef externalStyle fill:#50C878,stroke:#2E8B57,color:#fff
    classDef clientStyle fill:#FF6B6B,stroke:#C0392B,color:#fff

    class A1,A2 apiStyle
    class W1,W2,W3 workerStyle
    class R1,R2,R3,R4,R5 redisStyle
    class E1,E2 externalStyle
    class C1,C2,C3 clientStyle
